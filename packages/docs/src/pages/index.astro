---
import BaseLayout from '../layouts/BaseLayout.astro';
import PmTabs from '../components/PmTabs.astro';
import { iconSvgUrl } from '../lib/icons';

const heroIcons = [
    'clear-day', 'partly-cloudy-day-rain', 'thunderstorms-day-rain', 'snow',
    'wind', 'fog-day', 'overcast-day', 'rain',
    'hurricane', 'thermometer-warmer', 'clear-night', 'partly-cloudy-night',
];

const featureIcons = [
    {slug: 'clear-day', delay: 0},
    {slug: 'rain', delay: 0.6},
    {slug: 'snow', delay: 1.2},
    {slug: 'thunderstorms-day-rain', delay: 1.8},
    {slug: 'wind', delay: 2.4},
];

const weatherCards = [
    {
        style: 'fill',
        label: 'Fill',
        city: 'Barcelona',
        temp: '28',
        hi: '31', lo: '22',
        desc: 'Sunny',
        icon: 'clear-day',
        gradient: 'linear-gradient(135deg, #1b7fd4 0%, #0e94d4 50%, #2488c6 100%)',
        forecast: [
            {time: 'Now', icon: 'clear-day', temp: '28'},
            {time: '2PM', icon: 'clear-day', temp: '31'},
            {time: '4PM', icon: 'partly-cloudy-day', temp: '29'},
            {time: '6PM', icon: 'partly-cloudy-day', temp: '26'},
            {time: '8PM', icon: 'clear-night', temp: '23'},
        ],
    },
    {
        style: 'flat',
        label: 'Flat',
        city: 'Groenlo',
        temp: '14',
        hi: '16', lo: '11',
        desc: 'Light Rain',
        icon: 'partly-cloudy-day-rain',
        gradient: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
        forecast: [
            {time: 'Now', icon: 'partly-cloudy-day-rain', temp: '14'},
            {time: '2PM', icon: 'rain', temp: '13'},
            {time: '4PM', icon: 'rain', temp: '12'},
            {time: '6PM', icon: 'overcast', temp: '13'},
            {time: '8PM', icon: 'partly-cloudy-night', temp: '11'},
        ],
    },
    {
        style: 'line',
        label: 'Line',
        city: 'Reykjavik',
        temp: '-3',
        hi: '0', lo: '-6',
        desc: 'Heavy Snow',
        icon: 'snow',
        gradient: 'linear-gradient(135deg, #3b5e82 0%, #4e7599 50%, #5a84a8 100%)',
        forecast: [
            {time: 'Now', icon: 'snow', temp: '-3'},
            {time: '2PM', icon: 'snow', temp: '-2'},
            {time: '4PM', icon: 'snow', temp: '-4'},
            {time: '6PM', icon: 'overcast-snow', temp: '-5'},
            {time: '8PM', icon: 'snow', temp: '-6'},
        ],
    },
    {
        style: 'monochrome',
        label: 'Mono',
        city: 'Miami',
        temp: '31',
        hi: '33', lo: '26',
        desc: 'Thunderstorms',
        icon: 'thunderstorms-day-rain',
        gradient: 'linear-gradient(135deg, #1a1d2e 0%, #252942 50%, #2e3350 100%)',
        forecast: [
            {time: 'Now', icon: 'thunderstorms-day-rain', temp: '31'},
            {time: '2PM', icon: 'thunderstorms-rain', temp: '29'},
            {time: '4PM', icon: 'rain', temp: '27'},
            {time: '6PM', icon: 'overcast', temp: '27'},
            {time: '8PM', icon: 'partly-cloudy-night', temp: '26'},
        ],
    },
];
---

<BaseLayout title="Home">
    <main>
        <!-- Hero -->
        <section class="hero">
            <div class="hero-glow"/>
            <div class="hero-inner">
                <div class="hero-badge fade-up">
                    <span class="hero-badge-dot"></span>
                    <span>500+ animated icons</span>
                </div>
                <h1 class="hero-title fade-up delay-1">
                    Weather icons<br/>
                    that <span class="highlight">feel alive</span>
                </h1>
                <p class="hero-subtitle fade-up delay-2">
                    Beautiful, hand-crafted animated weather icons.<br/>
                    Open source. SVG and Lottie. Ready for any platform.
                </p>
                <div class="hero-actions fade-up delay-3">
                    <a href="/icons" class="btn btn-primary">
                        <span>Browse all icons</span>
                        <svg viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                            <path d="M569 337C578.4 327.6 578.4 312.4 569 303.1L401 135C391.6 125.6 376.4 125.6 367.1 135C357.8 144.4 357.7 159.6 367.1 168.9L494.1 295.9L88 295.9C74.7 295.9 64 306.6 64 319.9C64 333.2 74.7 343.9 88 343.9L494.1 343.9L367.1 470.9C357.7 480.3 357.7 495.5 367.1 504.8C376.5 514.1 391.7 514.2 401 504.8L569 337z"/>
                        </svg>
                    </a>
                    <a href="/docs/getting-started" class="btn btn-ghost">Get started</a>
                </div>
            </div>

            <div class="hero-showcase fade-up delay-4">
                <div class="showcase-track">
                    {[...heroIcons, ...heroIcons, ...heroIcons].map((slug, i) => (
                        <div class="showcase-item" aria-hidden={i >= heroIcons.length}>
                            <img src={iconSvgUrl('fill', slug)} alt={i < heroIcons.length ? slug : ''} width="80" height="80" loading="eager"/>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Floating preview -->
        <section class="preview-strip">
            <div class="preview-inner">
                {featureIcons.map(({slug, delay}) => (
                    <div class="preview-card" style={`animation-delay: ${delay}s`}>
                        <img src={iconSvgUrl('fill', slug)} alt={slug} width="64" height="64"/>
                    </div>
                ))}
            </div>
        </section>

        <!-- Features -->
        <section class="features">
            <div class="features-inner">
                <div class="section-label fade-up">Why Meteocons</div>
                <h2 class="section-title fade-up delay-1">Everything you need<br/>for weather UI</h2>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-number">500+</div>
                        <div class="feature-text">
                            <h3>Unique icons</h3>
                            <p>Weather conditions, thermometers, barometers, wind indicators, moon phases, UV index, and alerts.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">4</div>
                        <div class="feature-text">
                            <h3>Distinct styles</h3>
                            <p>Fill, Flat, Line, and Monochrome — each icon meticulously crafted in every variant.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">2</div>
                        <div class="feature-text">
                            <h3>Output formats</h3>
                            <p>Animated SVG for the web. Lottie JSON for native apps, After Effects, and beyond.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">&infin;</div>
                        <div class="feature-text">
                            <h3>Possibilities</h3>
                            <p>Works with React, Vue, Svelte, Angular, iOS, Android — any platform that renders SVG or Lottie.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Styles showcase -->
        <section class="styles-section">
            <div class="styles-inner">
                <div class="section-label">Styles</div>
                <h2 class="section-title">Four looks, one icon set</h2>

                <div class="weather-cards">
                    {weatherCards.map(card => (
                        <a href={`/icons?style=${card.style}`} class:list={['weather-card', `weather-${card.style}`]} style={`background: ${card.gradient};`}>
                            <span class="weather-style-tag">{card.label}</span>

                            <div class="weather-header">
                                <div class="weather-location">
                                    <div class="weather-city">{card.city}</div>
                                    <div class="weather-desc">{card.desc}</div>
                                </div>
                                <img src={iconSvgUrl(card.style, card.icon)} alt="" width="96" height="96" class="weather-icon"/>
                            </div>

                            <div class="weather-temp-row">
                                <span class="weather-temp">{card.temp}&deg;</span>
                                <span class="weather-hilo">H:{card.hi}&deg; L:{card.lo}&deg;</span>
                            </div>

                            <div class="weather-forecast">
                                {card.forecast.map(h => (
                                    <div class="forecast-hour">
                                        <span class="forecast-time">{h.time}</span>
                                        <img src={iconSvgUrl(card.style, h.icon)} alt="" width="40" height="40"/>
                                        <span class="forecast-temp">{h.temp}&deg;</span>
                                    </div>
                                ))}
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <!-- Install -->
        <section class="install-section">
            <div class="install-inner">
                <div class="install-glow"/>
                <div class="section-label">Get started</div>
                <h2 class="section-title">One command away</h2>
                <div class="install-cards">
                    <div class="install-card">
                        <div class="install-label">
                            <svg viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                                <path d="M192 112L304 112L304 200C304 239.8 336.2 272 376 272L464 272L464 512C464 520.8 456.8 528 448 528L192 528C183.2 528 176 520.8 176 512L176 128C176 119.2 183.2 112 192 112zM352 131.9L444.1 224L376 224C362.7 224 352 213.3 352 200L352 131.9zM192 64C156.7 64 128 92.7 128 128L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 250.5C512 233.5 505.3 217.2 493.3 205.2L370.7 82.7C358.7 70.7 342.5 64 325.5 64L192 64zM298.2 359.6C306.8 349.5 305.7 334.4 295.6 325.8C285.5 317.2 270.4 318.3 261.8 328.4L213.8 384.4C206.1 393.4 206.1 406.6 213.8 415.6L261.8 471.6C270.4 481.7 285.6 482.8 295.6 474.2C305.6 465.6 306.8 450.4 298.2 440.4L263.6 400L298.2 359.6zM378.2 328.4C369.6 318.3 354.4 317.2 344.4 325.8C334.4 334.4 333.2 349.6 341.8 359.6L376.4 400L341.8 440.4C333.2 450.5 334.3 465.6 344.4 474.2C354.5 482.8 369.6 481.7 378.2 471.6L426.2 415.6C433.9 406.6 433.9 393.4 426.2 384.4L378.2 328.4z"/>
                            </svg>
                            SVG
                        </div>
                        <PmTabs
                            id="home-svg"
                            bun="bun add @meteocons/svg"
                            npm="npm install @meteocons/svg"
                            yarn="yarn add @meteocons/svg"
                            pnpm="pnpm add @meteocons/svg"
                        />
                    </div>
                    <div class="install-card">
                        <div class="install-label">
                            <svg viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                                <path d="M323.4 112.7L494.8 192L323.4 271.2C321.3 272.2 318.8 272.2 316.7 271.2L145.2 192L316.6 112.7C318.7 111.7 321.2 111.7 323.3 112.7zM343.5 69.2C328.6 62.3 311.4 62.3 296.5 69.2L77.9 170.2C69.4 174.1 64 182.6 64 192C64 201.4 69.4 209.9 77.9 213.8L296.5 314.8C311.4 321.7 328.6 321.7 343.5 314.8L562.1 213.8C570.6 209.9 576 201.4 576 192C576 182.6 570.6 174.1 562.1 170.2L343.5 69.2zM112.1 282.4L77.9 298.2C69.4 302.1 64 310.6 64 320C64 329.4 69.4 337.9 77.9 341.8L296.5 442.8C311.4 449.7 328.6 449.7 343.5 442.8L562.1 341.8C570.6 337.9 576 329.4 576 320C576 310.6 570.6 302.1 562.1 298.2L528 282.4L470.8 308.8L494.9 319.9L323.5 399.1C321.4 400.1 318.9 400.1 316.8 399.1L145.2 320L169.3 308.9L112.1 282.4zM77.9 426.2C69.4 430.1 64 438.6 64 448C64 457.4 69.4 465.9 77.9 469.8L296.5 570.8C311.4 577.7 328.6 577.7 343.5 570.8L562.1 469.8C570.6 465.9 576 457.4 576 448C576 438.6 570.6 430.1 562.1 426.2L528 410.4L470.8 436.8L494.9 447.9L323.5 527.1C321.4 528.1 318.9 528.1 316.8 527.1L145.4 447.9L169.5 436.8L112.3 410.4L78.2 426.2z"/>
                            </svg>
                            Lottie
                        </div>
                        <PmTabs
                            id="home-lottie"
                            bun="bun add @meteocons/lottie"
                            npm="npm install @meteocons/lottie"
                            yarn="yarn add @meteocons/lottie"
                            pnpm="pnpm add @meteocons/lottie"
                        />
                    </div>
                </div>
                <div class="install-actions">
                    <a href="/docs/getting-started" class="btn btn-primary">
                        Read the docs
                        <svg viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                            <path d="M569 337C578.4 327.6 578.4 312.4 569 303.1L401 135C391.6 125.6 376.4 125.6 367.1 135C357.8 144.4 357.7 159.6 367.1 168.9L494.1 295.9L88 295.9C74.7 295.9 64 306.6 64 319.9C64 333.2 74.7 343.9 88 343.9L494.1 343.9L367.1 470.9C357.7 480.3 357.7 495.5 367.1 504.8C376.5 514.1 391.7 514.2 401 504.8L569 337z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* Hero */
    .hero {
        position: relative;
        text-align: center;
        padding: 99px 27px 0;
        overflow: hidden;
    }

    .hero-glow {
        position: absolute;
        top: -300px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 700px;
        background: radial-gradient(ellipse, rgba(229, 133, 10, 0.12) 0%, rgba(229, 133, 10, 0.04) 40%, transparent 70%);
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        padding: 6px 18px;
        background: var(--amber-glow);
        border: 2px solid var(--border-amber);
        border-radius: 100px;
        font-size: 14px;
        font-weight: 600;
        color: var(--amber);
        margin-bottom: 36px;
    }

    .hero-badge-dot {
        width: 6px;
        height: 6px;
        background: var(--amber);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--amber);
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(3.2rem, 7.5vw, 5.5rem);
        font-weight: 800;
        line-height: 1.02;
        letter-spacing: -0.035em;
        color: var(--text);
    }

    .hero-title .highlight {
        background: linear-gradient(135deg, var(--amber) 0%, #f5c84a 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        margin-top: 27px;
        font-size: 19px;
        color: var(--text-secondary);
        line-height: 1.7;
        font-weight: 400;
    }

    .hero-actions {
        margin-top: 45px;
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        padding: 15px 30px;
        border-radius: var(--radius-md);
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 15px;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: var(--amber);
        color: white;
        box-shadow: 0 6px 15px rgba(229, 133, 10, 0.3);
    }

    .btn-primary:hover {
        background: var(--amber-light);
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 12px 33px rgba(229, 133, 10, 0.35);
    }

    .btn-ghost {
        background: transparent;
        color: var(--text-secondary);
        border: 2px solid var(--border-light);
    }

    .btn-ghost:hover {
        color: var(--text);
        border-color: var(--amber);
        background: var(--amber-glow);
    }

    /* Showcase marquee */
    .hero-showcase {
        margin-top: 81px;
        overflow: hidden;
        mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }

    .showcase-track {
        display: flex;
        gap: 24px;
        animation: scroll 40s linear infinite;
        width: max-content;
    }

    .showcase-item {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @keyframes scroll {
        to {
            transform: translateX(-33.333%);
        }
    }

    /* Preview strip */
    .preview-strip {
        display: none;
    }

    /* Features */
    .features {
        padding: 159px 27px 0;
    }

    .features-inner {
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .section-label {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--amber);
        margin-bottom: 15px;
    }

    .section-title {
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 4.5vw, 3.4rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 72px;
    }

    .feature-list {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
    }

    .feature-item {
        padding: 0 33px;
        border-left: 2px solid var(--border-light);
    }

    .feature-item:first-child {
        padding-left: 0;
        border-left: none;
    }

    .feature-item:last-child {
        padding-right: 0;
    }

    .feature-item::before {
        content: '';
        display: block;
        width: 42px;
        height: 6px;
        background: var(--amber);
        border-radius: 3px;
        margin-bottom: 27px;
    }

    .feature-number {
        font-family: var(--font-display);
        font-size: 56px;
        font-weight: 800;
        color: var(--amber);
        line-height: 1;
        margin-bottom: 15px;
    }

    .feature-text h3 {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 18px;
        margin-bottom: 9px;
        color: var(--text);
    }

    .feature-text p {
        color: var(--text-secondary);
        font-size: 14px;
        line-height: 1.65;
    }

    /* Styles */
    .styles-section {
        padding: 159px 27px 0;
    }

    .styles-inner {
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .weather-cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 21px;
    }

    .weather-card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 27px;
        border-radius: var(--radius-xl);
        text-decoration: none;
        color: white;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
        border: 2px solid rgba(255, 255, 255, 0.08);
    }

    .weather-card:hover {
        color: white;
        transform: translateY(-6px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        border-color: rgba(255, 255, 255, 0.15);
    }

    .weather-style-tag {
        position: absolute;
        top: 18px;
        right: 18px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        padding: 3px 12px;
        border-radius: 100px;
    }

    .weather-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 6px;
    }

    .weather-location {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .weather-city {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 18px;
        letter-spacing: -0.01em;
    }

    .weather-desc {
        font-size: 14px;
        opacity: 0.75;
    }

    .weather-icon {
        flex-shrink: 0;
        margin-top: -6px;
        margin-right: -6px;
    }

    .weather-temp-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 21px;
    }

    .weather-temp {
        font-family: var(--font-display);
        font-size: 56px;
        font-weight: 300;
        line-height: 1;
    }

    .weather-hilo {
        font-size: 14px;
        opacity: 0.65;
        font-weight: 500;
    }

    .weather-forecast {
        display: flex;
        justify-content: space-between;
        padding-top: 15px;
        border-top: 2px solid rgba(255, 255, 255, 0.18);
    }

    .forecast-hour {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 9px;
    }

    .forecast-time {
        font-size: 12px;
        font-weight: 600;
        opacity: 0.65;
        text-transform: uppercase;
    }

    .forecast-temp {
        font-size: 14px;
        font-weight: 500;
    }

    .weather-monochrome img {
        filter: brightness(0) invert(1);
    }

    /* Install */
    .install-section {
        position: relative;
        padding: 159px 27px 0;
        text-align: center;
    }

    .install-inner {
        position: relative;
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .install-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(ellipse, rgba(229, 133, 10, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .install-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 21px;
        margin-top: 48px;
    }

    .install-card {
        background: var(--bg-soft);
        border-radius: var(--radius-lg);
        padding: 33px;
        text-align: left;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .install-card:hover {
        background: var(--bg-surface);
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .install-label {
        display: flex;
        align-items: center;
        gap: 9px;
        font-family: var(--font-display);
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 21px;
    }

    .install-label svg {
        color: var(--amber);
    }

