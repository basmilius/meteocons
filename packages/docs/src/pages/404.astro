---
import BaseLayout from '../layouts/BaseLayout.astro';
import { iconSvgUrl } from '../lib/icons';
---

<BaseLayout title="Page not found">
    <div class="not-found">
        <img src={iconSvgUrl('fill', 'thunderstorms-extreme')} alt="" width="128" height="128"/>
        <h1>404</h1>
        <p>This page doesn't exist.</p>
        <a href="/" class="back-link">
            <svg viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M71 303C61.6 312.4 61.6 327.6 71 336.9L239 505C248.4 514.4 263.6 514.4 272.9 505C282.2 495.6 282.3 480.4 272.9 471.1L145.9 344L552 344C565.3 344 576 333.3 576 320C576 306.7 565.3 296 552 296L145.9 296L273 169C282.4 159.6 282.4 144.4 273 135.1C263.6 125.8 248.4 125.7 239.1 135.1L71 303z"/>
            </svg>
            Back to home
        </a>
    </div>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 60vh;
        padding: 60px 27px;
        gap: 12px;
    }

    .not-found h1 {
        font-family: var(--font-display);
        font-size: 64px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
    }

    .not-found p {
        color: var(--text-muted);
        font-size: 18px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 15px;
        padding: 9px 21px;
        border-radius: var(--radius-md);
        font-weight: 500;
        font-size: 14px;
        color: var(--amber);
        background: var(--amber-bg);
        transition: all 0.15s;
    }

    .back-link:hover {
        color: var(--amber);
        background: var(--amber-glow);
    }
</style>
