---
import BaseLayout from '../layouts/BaseLayout.astro';
import PmTabs from '../components/PmTabs.astro';

const heroIcons = [
    'clear-day', 'partly-cloudy-day-rain', 'thunderstorms-day-rain', 'snow',
    'wind', 'fog-day', 'overcast-day', 'rain',
    'hurricane', 'thermometer-warmer', 'clear-night', 'partly-cloudy-night',
];

const featureIcons = [
    {slug: 'clear-day', delay: 0},
    {slug: 'rain', delay: 0.6},
    {slug: 'snow', delay: 1.2},
    {slug: 'thunderstorms-day-rain', delay: 1.8},
    {slug: 'wind', delay: 2.4},
];

const weatherCards = [
    {
        style: 'fill',
        label: 'Fill',
        city: 'Barcelona',
        temp: '28',
        hi: '31', lo: '22',
        desc: 'Sunny',
        icon: 'clear-day',
        gradient: 'linear-gradient(135deg, #1b7fd4 0%, #0e94d4 50%, #2488c6 100%)',
        forecast: [
            {time: 'Now', icon: 'clear-day', temp: '28'},
            {time: '2PM', icon: 'clear-day', temp: '31'},
            {time: '4PM', icon: 'partly-cloudy-day', temp: '29'},
            {time: '6PM', icon: 'partly-cloudy-day', temp: '26'},
            {time: '8PM', icon: 'clear-night', temp: '23'},
        ],
    },
    {
        style: 'flat',
        label: 'Flat',
        city: 'Groenlo',
        temp: '14',
        hi: '16', lo: '11',
        desc: 'Light Rain',
        icon: 'partly-cloudy-day-rain',
        gradient: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
        forecast: [
            {time: 'Now', icon: 'partly-cloudy-day-rain', temp: '14'},
            {time: '2PM', icon: 'rain', temp: '13'},
            {time: '4PM', icon: 'rain', temp: '12'},
            {time: '6PM', icon: 'overcast', temp: '13'},
            {time: '8PM', icon: 'partly-cloudy-night', temp: '11'},
        ],
    },
    {
        style: 'line',
        label: 'Line',
        city: 'Reykjavik',
        temp: '-3',
        hi: '0', lo: '-6',
        desc: 'Heavy Snow',
        icon: 'snow',
        gradient: 'linear-gradient(135deg, #3b5e82 0%, #4e7599 50%, #5a84a8 100%)',
        forecast: [
            {time: 'Now', icon: 'snow', temp: '-3'},
            {time: '2PM', icon: 'snow', temp: '-2'},
            {time: '4PM', icon: 'snow', temp: '-4'},
            {time: '6PM', icon: 'overcast-snow', temp: '-5'},
            {time: '8PM', icon: 'snow', temp: '-6'},
        ],
    },
    {
        style: 'monochrome',
        label: 'Mono',
        city: 'Miami',
        temp: '31',
        hi: '33', lo: '26',
        desc: 'Thunderstorms',
        icon: 'thunderstorms-day-rain',
        gradient: 'linear-gradient(135deg, #1a1d2e 0%, #252942 50%, #2e3350 100%)',
        forecast: [
            {time: 'Now', icon: 'thunderstorms-day-rain', temp: '31'},
            {time: '2PM', icon: 'thunderstorms-rain', temp: '29'},
            {time: '4PM', icon: 'rain', temp: '27'},
            {time: '6PM', icon: 'overcast', temp: '27'},
            {time: '8PM', icon: 'partly-cloudy-night', temp: '26'},
        ],
    },
];
---

<BaseLayout title="Home">
    <main>
        <!-- Hero -->
        <section class="hero">
            <div class="hero-glow"/>
            <div class="hero-inner">
                <div class="hero-badge fade-up">
                    <span class="hero-badge-dot"></span>
                    <span>475+ animated icons</span>
                </div>
                <h1 class="hero-title fade-up delay-1">
                    Weather icons<br/>
                    that <span class="highlight">feel alive</span>
                </h1>
                <p class="hero-subtitle fade-up delay-2">
                    Beautiful, hand-crafted animated weather icons.<br/>
                    Open source. SVG and Lottie. Ready for any platform.
                </p>
                <div class="hero-actions fade-up delay-3">
                    <a href="/icons" class="btn btn-primary">
                        <span>Browse all icons</span>
                        <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <path d="M5 10h10M11 6l4 4-4 4"/>
                        </svg>
                    </a>
                    <a href="/docs/getting-started" class="btn btn-ghost">Get started</a>
                </div>
            </div>

            <div class="hero-showcase fade-up delay-4">
                <div class="showcase-track">
                    {[...heroIcons, ...heroIcons, ...heroIcons].map((slug, i) => (
                        <div class="showcase-item" aria-hidden={i >= heroIcons.length}>
                            <img src={`/icons/fill/${slug}.svg`} alt={i < heroIcons.length ? slug : ''} width="80" height="80" loading="eager"/>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Floating preview -->
        <section class="preview-strip">
            <div class="preview-inner">
                {featureIcons.map(({slug, delay}) => (
                    <div class="preview-card" style={`animation-delay: ${delay}s`}>
                        <img src={`/icons/fill/${slug}.svg`} alt={slug} width="64" height="64"/>
                    </div>
                ))}
            </div>
        </section>

        <!-- Features -->
        <section class="features">
            <div class="features-inner">
                <div class="section-label fade-up">Why Meteocons</div>
                <h2 class="section-title fade-up delay-1">Everything you need<br/>for weather UI</h2>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-number">475+</div>
                        <div class="feature-text">
                            <h3>Unique icons</h3>
                            <p>Weather conditions, thermometers, barometers, wind indicators, moon phases, UV index, and alerts.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">4</div>
                        <div class="feature-text">
                            <h3>Distinct styles</h3>
                            <p>Fill, Flat, Line, and Monochrome — each icon meticulously crafted in every variant.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">2</div>
                        <div class="feature-text">
                            <h3>Output formats</h3>
                            <p>Animated SVG for the web. Lottie JSON for native apps, After Effects, and beyond.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-number">&infin;</div>
                        <div class="feature-text">
                            <h3>Possibilities</h3>
                            <p>Works with React, Vue, Svelte, Angular, iOS, Android — any platform that renders SVG or Lottie.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Styles showcase -->
        <section class="styles-section">
            <div class="styles-inner">
                <div class="section-label">Styles</div>
                <h2 class="section-title">Four looks, one icon set</h2>

                <div class="weather-cards">
                    {weatherCards.map(card => (
                        <a href={`/icons?style=${card.style}`} class:list={['weather-card', `weather-${card.style}`]} style={`background: ${card.gradient};`}>
                            <span class="weather-style-tag">{card.label}</span>

                            <div class="weather-header">
                                <div class="weather-location">
                                    <div class="weather-city">{card.city}</div>
                                    <div class="weather-desc">{card.desc}</div>
                                </div>
                                <img src={`/icons/${card.style}/${card.icon}.svg`} alt="" width="96" height="96" class="weather-icon"/>
                            </div>

                            <div class="weather-temp-row">
                                <span class="weather-temp">{card.temp}&deg;</span>
                                <span class="weather-hilo">H:{card.hi}&deg; L:{card.lo}&deg;</span>
                            </div>

                            <div class="weather-forecast">
                                {card.forecast.map(h => (
                                    <div class="forecast-hour">
                                        <span class="forecast-time">{h.time}</span>
                                        <img src={`/icons/${card.style}/${h.icon}.svg`} alt="" width="40" height="40"/>
                                        <span class="forecast-temp">{h.temp}&deg;</span>
                                    </div>
                                ))}
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <!-- Install -->
        <section class="install-section">
            <div class="install-inner">
                <div class="install-glow"/>
                <div class="section-label">Get started</div>
                <h2 class="section-title">One command away</h2>
                <div class="install-cards">
                    <div class="install-card">
                        <div class="install-label">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <path d="M3 9h18"/>
                            </svg>
                            SVG
                        </div>
                        <PmTabs
                            id="home-svg"
                            bun="bun add @meteocons/svg"
                            npm="npm install @meteocons/svg"
                            yarn="yarn add @meteocons/svg"
                            pnpm="pnpm add @meteocons/svg"
                        />
                    </div>
                    <div class="install-card">
                        <div class="install-label">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5"/>
                                <path d="M2 12l10 5 10-5"/>
                            </svg>
                            Lottie
                        </div>
                        <PmTabs
                            id="home-lottie"
                            bun="bun add @meteocons/lottie"
                            npm="npm install @meteocons/lottie"
                            yarn="yarn add @meteocons/lottie"
                            pnpm="pnpm add @meteocons/lottie"
                        />
                    </div>
                </div>
                <div class="install-actions">
                    <a href="/docs/getting-started" class="btn btn-primary">
                        Read the docs
                        <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <path d="M5 10h10M11 6l4 4-4 4"/>
                        </svg>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* Hero */
    .hero {
        position: relative;
        text-align: center;
        padding: 100px 28px 0;
        overflow: hidden;
    }

    .hero-glow {
        position: absolute;
        top: -300px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 700px;
        background: radial-gradient(ellipse, rgba(229, 133, 10, 0.12) 0%, rgba(229, 133, 10, 0.04) 40%, transparent 70%);
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 7px 18px;
        background: var(--amber-glow);
        border: 1px solid var(--border-amber);
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--amber);
        margin-bottom: 36px;
    }

    .hero-badge-dot {
        width: 6px;
        height: 6px;
        background: var(--amber);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--amber);
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(3.2rem, 7.5vw, 5.5rem);
        font-weight: 800;
        line-height: 1.02;
        letter-spacing: -0.035em;
        color: var(--text);
    }

    .hero-title .highlight {
        background: linear-gradient(135deg, var(--amber) 0%, #f5c84a 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        margin-top: 28px;
        font-size: 1.2rem;
        color: var(--text-secondary);
        line-height: 1.7;
        font-weight: 400;
    }

    .hero-actions {
        margin-top: 44px;
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 15px 30px;
        border-radius: var(--radius-md);
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.95rem;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: var(--amber);
        color: white;
        box-shadow: 0 4px 16px rgba(229, 133, 10, 0.3);
    }

    .btn-primary:hover {
        background: var(--amber-light);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 32px rgba(229, 133, 10, 0.35);
    }

    .btn-ghost {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border-light);
    }

    .btn-ghost:hover {
        color: var(--text);
        border-color: var(--amber);
        background: var(--amber-glow);
    }

    /* Showcase marquee */
    .hero-showcase {
        margin-top: 80px;
        overflow: hidden;
        mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }

    .showcase-track {
        display: flex;
        gap: 24px;
        animation: scroll 40s linear infinite;
        width: max-content;
    }

    .showcase-item {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @keyframes scroll {
        to {
            transform: translateX(-33.333%);
        }
    }

    /* Preview strip */
    .preview-strip {
        display: none;
    }

    /* Features */
    .features {
        padding: 160px 28px 0;
    }

    .features-inner {
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .section-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--amber);
        margin-bottom: 16px;
    }

    .section-title {
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 4.5vw, 3.4rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 72px;
    }

    .feature-list {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
    }

    .feature-item {
        padding: 0 32px;
        border-left: 1px solid var(--border-light);
    }

    .feature-item:first-child {
        padding-left: 0;
        border-left: none;
    }

    .feature-item:last-child {
        padding-right: 0;
    }

    .feature-item::before {
        content: '';
        display: block;
        width: 40px;
        height: 4px;
        background: var(--amber);
        border-radius: 2px;
        margin-bottom: 28px;
    }

    .feature-number {
        font-family: var(--font-display);
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--amber);
        line-height: 1;
        margin-bottom: 16px;
    }

    .feature-text h3 {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 10px;
        color: var(--text);
    }

    .feature-text p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.65;
    }

    /* Styles */
    .styles-section {
        padding: 160px 28px 0;
    }

    .styles-inner {
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .weather-cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .weather-card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 28px;
        border-radius: var(--radius-xl);
        text-decoration: none;
        color: white;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .weather-card:hover {
        color: white;
        transform: translateY(-6px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        border-color: rgba(255, 255, 255, 0.15);
    }

    .weather-style-tag {
        position: absolute;
        top: 18px;
        right: 18px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        padding: 4px 12px;
        border-radius: 100px;
    }

    .weather-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .weather-location {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .weather-city {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.01em;
    }

    .weather-desc {
        font-size: 0.9rem;
        opacity: 0.75;
    }

    .weather-icon {
        flex-shrink: 0;
        margin-top: -4px;
        margin-right: -4px;
    }

    .weather-temp-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 20px;
    }

    .weather-temp {
        font-family: var(--font-display);
        font-size: 3.5rem;
        font-weight: 300;
        line-height: 1;
    }

    .weather-hilo {
        font-size: 0.85rem;
        opacity: 0.65;
        font-weight: 500;
    }

    .weather-forecast {
        display: flex;
        justify-content: space-between;
        padding-top: 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.18);
    }

    .forecast-hour {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .forecast-time {
        font-size: 0.75rem;
        font-weight: 600;
        opacity: 0.65;
        text-transform: uppercase;
    }

    .forecast-temp {
        font-size: 0.85rem;
        font-weight: 500;
    }

    .weather-monochrome img {
        filter: brightness(0) invert(1);
    }

    /* Install */
    .install-section {
        position: relative;
        padding: 160px 28px 0;
        text-align: center;
    }

    .install-inner {
        position: relative;
        max-width: var(--content-width);
        margin: 0 auto;
    }

    .install-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(ellipse, rgba(229, 133, 10, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .install-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 48px;
    }

    .install-card {
        background: var(--bg-soft);
        border-radius: var(--radius-lg);
        padding: 32px;
        text-align: left;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .install-card:hover {
        background: var(--bg-surface);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .install-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 20px;
    }

    .install-label svg {
        color: var(--amber);
    }

    .install-card pre {
        margin: 0;
        font-size: 0.85rem;
    }

    .install-card :global(.pm-tabs) {
        margin-bottom: 0;
    }

    .install-actions {
        margin-top: 40px;
    }

    /* Responsive */
    @media (max-width: 640px) {
        .hero {
            padding-top: 64px;
        }

        .feature-list {
            grid-template-columns: repeat(2, 1fr);
            gap: 40px 0;
        }

        .feature-item:nth-child(3) {
            border-left: none;
            padding-left: 0;
        }

        .weather-cards {
            grid-template-columns: 1fr;
        }

        .weather-card {
            padding: 22px;
        }

        .weather-temp {
            font-size: 2.8rem;
        }

        .install-cards {
            grid-template-columns: 1fr;
        }

        .features,
        .styles-section,
        .install-section {
            padding-top: 100px;
        }
    }
</style>
