---
import '../styles/global.css';
import { version } from '../../package.json';
import { iconSvgUrl } from '../lib/icons';

interface Props {
    title: string;
    description?: string;
    fullWidth?: boolean;
}

const {title, description = 'Animated weather icons for the modern web. 500+ icons in SVG and Lottie.', fullWidth = false} = Astro.props;
const currentPath = Astro.url.pathname;
const displayVersion = version === '0.0.0' ? 'Dev' : `v${version}`;
---

<html lang="en">
    <head>
        <meta charset="utf-8"/>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <meta name="description" content={description}/>
        <meta name="generator" content={Astro.generator}/>
        <title>{title === 'Home' ? 'Meteocons — Animated Weather Icons' : `${title} — Meteocons`}</title>
        <meta property="og:title" content={title === 'Home' ? 'Meteocons' : title}/>
        <meta property="og:description" content={description}/>
        <meta property="og:image" content="/og.png"/>
        <meta property="og:type" content="website"/>
        <meta name="twitter:card" content="summary_large_image"/>
        <meta name="twitter:image" content="/og.png"/>
    </head>
    <body>
        <nav class="nav">
            <div class="nav-inner">
                <a href="/" class="nav-brand">
                    <img src={iconSvgUrl('fill', 'clear-day')} alt="" width="42" height="42"/>
                    <span>Meteocons</span>
                </a>
                <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" onclick="const nav=document.querySelector('.nav-links');const bd=document.querySelector('.nav-backdrop');const open=nav.classList.toggle('open');bd.classList.toggle('open',open);this.setAttribute('aria-expanded',open)">
                    <svg class="icon-menu" viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                        <path d="M96 152C96 138.7 106.7 128 120 128L520 128C533.3 128 544 138.7 544 152C544 165.3 533.3 176 520 176L120 176C106.7 176 96 165.3 96 152zM96 320C96 306.7 106.7 296 120 296L520 296C533.3 296 544 306.7 544 320C544 333.3 533.3 344 520 344L120 344C106.7 344 96 333.3 96 320zM544 488C544 501.3 533.3 512 520 512L120 512C106.7 512 96 501.3 96 488C96 474.7 106.7 464 120 464L520 464C533.3 464 544 474.7 544 488z"/>
                    </svg>
                    <svg class="icon-close" viewBox="0 0 640 640" width="20" height="20" fill="currentColor" aria-hidden="true">
                        <path d="M135.5 169C126.1 159.6 126.1 144.4 135.5 135.1C144.9 125.8 160.1 125.7 169.4 135.1L320.4 286.1L471.4 135.1C480.8 125.7 496 125.7 505.3 135.1C514.6 144.5 514.7 159.7 505.3 169L354.3 320L505.3 471C514.7 480.4 514.7 495.6 505.3 504.9C495.9 514.2 480.7 514.3 471.4 504.9L320.4 353.9L169.4 504.9C160 514.3 144.8 514.3 135.5 504.9C126.2 495.5 126.1 480.3 135.5 471L286.5 320L135.5 169z"/>
                    </svg>
                </button>
                <div class="nav-backdrop" onclick="const nav=document.querySelector('.nav-links');const btn=document.querySelector('.nav-toggle');nav.classList.remove('open');this.classList.remove('open');btn.setAttribute('aria-expanded','false')"></div>
                <div class="nav-links">
                    <a href="/" class:list={[{active: currentPath === '/'}]}>Home</a>
                    <a href="/icons" class:list={[{active: currentPath.startsWith('/icons')}]}>Icons</a>
                    <a href="/docs/getting-started" class:list={[{active: currentPath.startsWith('/docs')}]}>Docs</a>
                    <div class="nav-divider"></div>
                    <a href="https://bas.dev" target="_blank" rel="noopener" class="nav-icon" aria-label="bas.dev">
                        <svg viewBox="0 0 559 348" width="20" height="20" fill="currentColor" aria-hidden="true">
                            <path d="M179.85 185.43c23.1-9.18 39.17-35.1 33.61-69.12-5.9-36.04-35.98-64.82-84.28-56.95L24.2 76.48C5.97 79.46-2.52 92.08.65 111.52l34.17 209.01c3.24 19.83 15.3 29.1 33.55 26.13l109.16-17.8c48.3-7.88 68.5-44.44 61.87-84.95-5.56-34.02-31.82-58.44-59.55-58.48M57.71 121.27l67.68-11.04c18.27-2.98 31.78 8.12 34.5 24.73 2.84 17.42-6.5 31.83-24.77 34.8l-67.68 11.05zm97.74 160.94-69.59 11.34-10.4-63.66 69.58-11.35c21.3-3.48 35.1 9.25 37.88 26.26 3.18 19.44-6.93 34.06-27.47 37.4M470.45.69a47.4 47.4 0 0 0-38.92 37.5l-32.6 150.14-78.3-132.05a47.9 47.9 0 0 0-82.56-.4 48 48 0 0 0-6.13 31.93l32.74 200.3a29.76 29.76 0 0 0 33.95 24 29.2 29.2 0 0 0 23.82-33.42L294.9 110.06l104.09 174.88a16.81 16.81 0 0 0 30.87-5.04l42.98-198.86 27.56 168.63a29.45 29.45 0 0 0 58.09-9.47L525.75 39.94A47.8 47.8 0 0 0 470.45.7"/>
                        </svg>
                    </a>
                    <a href="https://github.com/basmilius/meteocons" target="_blank" rel="noopener" class="nav-icon" aria-label="GitHub">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                    </a>
                    <a href="https://www.npmjs.com/org/meteocons" target="_blank" rel="noopener" class="nav-icon" aria-label="npm">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                            <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323h13.837v13.069H11.89v-9.974H8.96v9.974H5.13z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </nav>

        <slot/>

        {!fullWidth && (
            <footer class="footer">
                <div class="footer-inner">
                    <div class="footer-top">
                        <div class="footer-brand">
                            <img src={iconSvgUrl('fill', 'clear-day')} alt="" width="24" height="24"/>
                            <span>Meteocons</span>
                        </div>
                        <div class="footer-links">
                            <a href="/icons">Icons</a>
                            <a href="/docs/getting-started">Docs</a>
                            <a href="https://github.com/basmilius/meteocons" target="_blank" rel="noopener">GitHub</a>
                            <a href="https://www.npmjs.com/org/meteocons" target="_blank" rel="noopener">npm</a>
                        </div>
                    </div>
                    <div class="footer-bottom">
                        <p>Designed and built by <a href="https://bas.dev" target="_blank" rel="noopener">Bas Milius</a></p>
                        <span class="footer-version">{displayVersion}</span>
                    </div>
                </div>
            </footer>
        )}
    </body>
</html>

<style>
    .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        height: var(--nav-height);
        background: white;
        border-bottom: 2px solid var(--border);
    }

    .nav-inner {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 0 27px;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .nav-brand {
        display: flex;
        margin-left: -3px;
        align-items: center;
        gap: 9px;
        color: var(--text);
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 21px;
        letter-spacing: -0.02em;
    }

    .nav-brand:hover {
        color: var(--text);
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .nav-divider {
        width: 1px;
        height: 24px;
        background: var(--border-light);
        margin: 0 9px;
    }

    .nav-links > a {
        color: var(--text-secondary);
        font-size: 16px;
        font-weight: 500;
        padding: 9px 18px;
        border-radius: var(--radius-sm);
        transition: all 0.15s;
    }

    .nav-links > a:hover {
        color: var(--text);
        background: var(--bg-soft);
    }

    .nav-links > a.active {
        color: var(--amber);
        font-weight: 600;
    }

    .nav-icon {
        display: flex;
        padding: 9px !important;
        color: var(--text-muted) !important;
    }

    .nav-icon:hover {
        color: var(--text-secondary) !important;
        background: var(--bg-soft);
    }

    .nav-backdrop {
        display: none;
    }

    .nav-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border: none;
        border-radius: var(--radius-sm);
        background: transparent;
        color: var(--text);
        cursor: pointer;
    }

    .nav-toggle:hover {
        background: var(--bg-soft);
    }

    .nav-toggle .icon-close {
        display: none;
    }

    .nav-toggle[aria-expanded="true"] .icon-menu {
        display: none;
    }

    .nav-toggle[aria-expanded="true"] .icon-close {
        display: block;
    }

    @media (max-width: 640px) {
        .nav-brand {
            margin-left: -12px;
        }

        .nav-inner {
            padding: 0 21px;
            justify-content: center;
        }

        .nav-toggle {
            display: flex;
            position: absolute;
            left: 21px;
            width: 45px;
            height: 45px;
            border-radius: var(--radius-md);
        }

        .nav-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            top: var(--nav-height);
            z-index: 49;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(4px);
            opacity: 0;
            transition: opacity 0.2s ease-out;
        }

        .nav-backdrop.open {
            display: block;
            opacity: 1;
        }

        .nav-links {
            position: absolute;
            top: var(--nav-height);
            left: 0;
            right: 0;
            z-index: 50;
            background: var(--bg);
            border-bottom: 2px solid var(--border);
            padding: 12px 21px 21px;
            flex-direction: column;
            gap: 3px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-9px);
            transition: opacity 0.2s ease-out, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.2s;
        }

        .nav-links.open {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .nav-links > a {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            font-weight: 500;
        }

        .nav-links > a.active {
            background: rgba(229, 133, 10, 0.06);
        }

        .nav-links > .nav-icon {
            padding: 12px 15px !important;
        }

        .nav-divider {
            width: 100%;
            height: 1px;
            margin: 9px 0;
        }
    }

    .footer {
        border-top: 2px solid var(--border);
        margin-top: 120px;
        padding: 48px 27px;
        background: var(--bg-soft);
    }

    .footer-inner {
        max-width: var(--content-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 27px;
    }

    .footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: 9px;
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 16px;
        color: var(--text);
    }

    .footer-links {
        display: flex;
        gap: 24px;
    }

    .footer-links a {
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 500;
        transition: color 0.15s;
    }

    .footer-links a:hover {
        color: var(--amber);
    }

    .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 21px;
        border-top: 2px solid var(--border);
    }

    .footer-bottom p {
        color: var(--text-muted);
        font-size: 13px;
    }

    .footer-version {
        font-size: 12px;
        font-weight: 600;
        color: var(--amber);
        background: rgba(229, 133, 10, 0.1);
        padding: 3px 12px;
        border-radius: 100px;
    }

    @media (max-width: 640px) {
        .footer-top {
            flex-direction: column;
            gap: 21px;
        }
    }
</style>
